{
  "name": "odse-schema-only-connector",
  "config": {
    "connector.class": "io.debezium.connector.sqlserver.SqlServerConnector",
    "database.hostname": "${env:DB_HOST}",
    "database.port": "${env:DB_PORT}",
    "database.user": "${env:DB_USERNAME}",
    "database.password": "${env:DB_PASSWORD}",
    "database.dbname": "nbs_odse",
    "database.names": "nbs_odse",
    "database.server.name": "odse-act-rel",
    "database.history.kafka.bootstrap.servers": "${env:KAFKA_SERVER}",
    "database.history.kafka.topic": "odse-act-rel.history",
    "database.trustServerCertificate": "true",
    "include.schema.changes": "true",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "true",
    "producer.max.request.size": "10000000",
    "producer.message.max.bytes": "10000000",
    "snapshot.mode": "schema_only",
    "schema.history.internal.kafka.topic": "odse-act-rel-schema-history",
    "schema.history.internal.kafka.bootstrap.servers": "${env:KAFKA_SERVER}",
    "table.include.list": "dbo.Act_relationship",
    "tasks.max": 1,
    "topic.prefix": "cdc_odse_act_rel",
    "topic.creation.default.replication.factor": 1,
    "topic.creation.default.partitions": 10,
    "topic.creation.default.cleanup.policy": "compact",
    "time.precision.mode": "connect",
    "transforms": "dropPrefix, convertTimezone",
    "transforms.dropPrefix.regex": "cdc_odse_act_rel\\.NBS_ODSE\\.dbo\\.(.+)",
    "transforms.dropPrefix.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.dropPrefix.replacement": "nbs_$1",
    "transforms.convertTimezone.type": "io.debezium.transforms.TimezoneConverter",
    "transforms.convertTimezone.converted.timezone": "UTC",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "true"
  }
}
