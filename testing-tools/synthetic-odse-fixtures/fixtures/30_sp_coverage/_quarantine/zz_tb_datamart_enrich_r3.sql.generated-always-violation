    PATIENT_WITHIN_CITY_LIMITS = N'Y',
    PATIENT_RACE_ASIAN_1       = N'Chinese',
    PATIENT_RACE_ASIAN_2       = N'Filipino',
    PATIENT_RACE_ASIAN_3       = N'Japanese',
    PATIENT_RACE_ASIAN_ALL     = N'Chinese | Filipino | Japanese',
    PATIENT_RACE_ASIAN_GT3_IND = N'FALSE',
    PATIENT_RACE_NAT_HI_1      = N'Native Hawaiian',
    PATIENT_RACE_NAT_HI_2      = N'Guamanian',
    PATIENT_RACE_NAT_HI_3      = N'Samoan',
    PATIENT_RACE_NAT_HI_ALL    = N'Native Hawaiian | Guamanian | Samoan',
