GO

-- =====================================================================
-- Cluster 6 — investigation attrs
--   GENERAL_COMMENTS, ILLNESS_DURATION, ILLNESS_DURATION_UNIT  <- INVESTIGATION dim
--   PROGRAM_AREA_DESCRIPTION  <- nrt_investigation
--   OUTBREAK_NAME  <- nrt_srte_Code_value_general desc of the dim's
--                     OUTBREAK_NAME code 'Cluster' (SP line 690/699-700).
-- =====================================================================
UPDATE [dbo].[INVESTIGATION]
SET INV_COMMENTS          = N'TB investigation general comments (R3 enrich).',
    ILLNESS_DURATION      = 21,
    ILLNESS_DURATION_UNIT = N'day(s)'
WHERE INVESTIGATION_KEY = 24;

UPDATE [dbo].[nrt_investigation]
SET program_area_description = N'Tuberculosis'
WHERE public_health_case_uid = 22001000;

-- OUTBREAK_NM code so cvg join resolves CODE='Cluster' -> OUTBREAK_NAME desc.
IF NOT EXISTS (SELECT 1 FROM [dbo].[nrt_srte_Code_value_general]
               WHERE code_set_nm = 'OUTBREAK_NM' AND code = 'Cluster')
BEGIN
    INSERT INTO [dbo].[nrt_srte_Code_value_general]
        (code_set_nm, code, code_desc_txt, code_short_desc_txt,
         status_cd, add_time, add_user_id)
    VALUES
        (N'OUTBREAK_NM', N'Cluster', N'TB Cluster Outbreak', N'TB Cluster Outbreak',
         N'A', '2026-04-01T00:00:00', 10009282);
END
GO

